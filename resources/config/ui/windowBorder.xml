<window
    x="${window.x}"
    y="${window.y}"
    width="${window.width}"
    height="calc('${window.height} + 100')"
    border="none"
>
    <variables>
        <set name="window.offset.x" value="0"/>
        <set name="window.offset.y" value="0"/>
    </variables>

    <panel x="0" y="0" width="${window.width}" height="${window.height}"/>
    <label x="0" y="${window.height}" width="${window.width}" height="100" text="${window.title}"/>
</window>
