<window
    id="shutdownOptions"
    x="calc('${screen.width} / 2 - ${shutdownOptions.width} / 2')"
    y="calc('${screen.height} / 2 - ${shutdownOptions.height} / 2')"
    width="${shutdownOptions.width}"
    height="${shutdownOptions.height}"
    border="fixedDialog"
    maximizeButton="false"
    autoShow="false">

    <tablePanel dock="fill" attrList="themedWindow" rowCount="3" columnCount="1" padding="${theme.paddingLarge},0,${theme.paddingLarge},${theme.paddingLarge}">
        <button dock="fill" attrList="flatButton" margin="0,${theme.paddingLarge},0,0" table.position="0,0" text="Shutdown" onClick="shellExecuteHidden('shutdown.exe', '/s /t 0')"/>
        <button dock="fill" attrList="flatButton" margin="0,${theme.paddingLarge},0,0" table.position="0,1" text="Reboot" onClick="shellExecuteHidden('shutdown.exe', '/r /t 0')"/>
        <button dock="fill" attrList="flatButton" margin="0,${theme.paddingLarge},0,0" table.position="0,2" text="Cancel" onClick="window.hide(shutdownOptions)"/>
    </tablePanel>
</window>
