<tablePanel
    x="calc('${taskbar.width} - ${taskbar.tray.width} - ${theme.paddingMiddle} * 2')"
    y="0"
    width="${taskbar.tray.width}"
    height="${taskbar.height}"
    updateInterval="100"
    color="${theme.font.color}"
    font="${theme.font.main}"
    rowCount="1"
    columnCount="2"
    padding="${theme.paddingMiddle}"
    >

    <label dock="fill" table.position="0,0" align="middleCenter" text="concat(media.getBatteryLevel(), '%')"/>
    <label dock="fill" table.position="1,0" align="middleCenter" text="dateTime('HH:mm:ss')"/>
</tablePanel>
